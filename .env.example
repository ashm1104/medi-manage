# Copy this file to .env for local development.
# In Render, set these in the dashboard Environment section instead.
#
# DATABASE_URL
# Use the Supabase pooler connection string (IPv4-friendly) for hosted environments.
# Local Postgres example:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/secure_health_hub
# Supabase pooler example:
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-YOUR-REGION.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-YOUR-REGION.pooler.supabase.com:6543/postgres?sslmode=require

# Frontend Supabase client config (safe to expose in browser)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
